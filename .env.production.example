APP_NAME=LedgerFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ledgerflow.example.com

DEMO_MODE=false

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=120
QUEUE_FAILED_DRIVER=database-uuids
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

MAIL_MAILER=log
